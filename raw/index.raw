    <button class="nav-link active" id="demo-cb-pill" data-bs-toggle="tab" data-bs-target="#cb-pill-pane" type="button" role="tab" aria-controls="cb-pill-pane">style=pill</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="demo-cb-dot" data-bs-toggle="tab" data-bs-target="#cb-dot-pane" type="button" role="tab" aria-controls="cb-dot-pane">style=dot</button>
  </li>
  </ul>
  <div class="tab-content" id="demo-cb-content">
