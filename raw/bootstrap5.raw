  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="demo-cbreq-dot" data-bs-toggle="tab" data-bs-target="#cbreq-dot-pane" type="button" role="tab" aria-controls="cbreq-dot-pane">style=dot</button>
  </li>
  </ul>
  <div class="tab-content" id="demo-cbreq-content">
    <div class="tab-pane fade show active" id="cbreq-pill-pane" role="tabpanel" aria-labelledby="demo-cbreq-pill" tabindex="0">

#fragment/bs5/cbreq1.pill.form
      <br>
#fragment/bs5/cbreq2.pill.form

